}


###
# @name car2
POST {{baseUrl}}/vehicles/
Authorization: Bearer {{loginSecondOwner.response.body.access}}
Content-Type: {{json}}

{
  "vendor": "{{vendorB.response.body.id}}",
  "make": "Audi",
  "model": "A6",
  "year": 2024,
  "license_plate": "DELTA-002",
  "daily_rate": "120"
}


### =====================================================
### 8. LIST VEHICLES WITH SEARCH AND FILTER
### =====================================================

###
GET {{baseUrl}}/vehicles/?search=BMW
Authorization: Bearer {{loginOwner.response.body.access}}


###
GET {{baseUrl}}/vehicles/?vendor={{vendorB.response.body.id}}
Authorization: Bearer {{loginOwner.response.body.access}}


###
GET {{baseUrl}}/vehicles/?status=ACTIVE
Authorization: Bearer {{loginOwner.response.body.access}}


### =====================================================
### 9. UPDATE AND VERIFY VEHICLE
### =====================================================

###
PATCH {{baseUrl}}/vehicles/{{car1.response.body.id}}/
Authorization: Bearer {{loginSecondOwner.response.body.access}}
Content-Type: {{json}}

{
  "daily_rate": "180"
}


###
GET {{baseUrl}}/vehicles/{{car1.response.body.id}}/
Authorization: Bearer {{loginSecondOwner.response.body.access}}


### =====================================================
### 10. CREATE DRIVER
### =====================================================

###
# @name driver1
POST {{baseUrl}}/drivers/
Authorization: Bearer {{loginSecondOwner.response.body.access}}
Content-Type: {{json}}

{
  "vendor": "{{vendorB.response.body.id}}",
  "full_name": "Dennis Driver",
  "license_number": "DRIVER-001",
  "is_active": true
}


###
GET {{baseUrl}}/drivers/?vendor={{vendorB.response.body.id}}
Authorization: Bearer {{loginSecondOwner.response.body.access}}


### =====================================================
### 11. CREATE BOOKING
### =====================================================

###
# @name booking_request1
POST {{baseUrl}}/bookings/
Authorization: Bearer {{loginCustomer.response.body.access}}
Content-Type: {{json}}

{
  "vehicle": "{{car1.response.body.id}}",
  "type": "SELF_DRIVE",
  "start_at": "2026-09-10T10:00:00Z",
  "end_at": "2026-09-15T10:00:00Z"
}


### =====================================================
### 12. BOOKING LIST AND FILTER
### =====================================================

###
GET {{baseUrl}}/bookings/
Authorization: Bearer {{loginCustomer.response.body.access}}


###
GET {{baseUrl}}/bookings/?status=PENDING
Authorization: Bearer {{loginCustomer.response.body.access}}


###
GET {{baseUrl}}/bookings/?vehicle={{car1.response.body.id}}
Authorization: Bearer {{loginCustomer.response.body.access}}


### =====================================================
### 13. OWNER CONFIRMS BOOKING
### =====================================================

###
POST {{baseUrl}}/bookings/{{booking_request1.response.body.id}}/approve/
Authorization: Bearer {{loginSecondOwner.response.body.access}}


### =====================================================
### 14. ASSIGN DRIVER TO BOOKING
### =====================================================

###
POST {{baseUrl}}/bookings/{{booking_request1.response.body.id}}/assign-driver/
Authorization: Bearer {{loginSecondOwner.response.body.access}}
Content-Type: {{json}}

{
  "driver_id": "{{driver1.response.body.id}}"
}


### =====================================================
### 15. COMPLETE BOOKING
### =====================================================

###
POST {{baseUrl}}/bookings/{{booking_request1.response.body.id}}/complete/
Authorization: Bearer {{loginSecondOwner.response.body.access}}


### =====================================================
### 16. PAYMENT FLOW
### =====================================================

###
# @name payment1
POST {{baseUrl}}/payments/
Authorization: Bearer {{loginCustomer.response.body.access}}
Content-Type: {{json}}

{
  "booking": "{{booking_request1.response.body.id}}",
  "amount": "750",
  "method": "CARD",
  "reference": "PAY-REF-001"
}


###
POST {{baseUrl}}/payments/{{payment1.response.body.id}}/mark_paid/
Authorization: Bearer {{loginAdmin.response.body.access}}


###
POST {{baseUrl}}/payments/{{payment1.response.body.id}}/refund/
Authorization: Bearer {{loginAdmin.response.body.access}}


###
GET {{baseUrl}}/payments/?booking={{booking_request1.response.body.id}}
Authorization: Bearer {{loginAdmin.response.body.access}}



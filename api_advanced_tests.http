### =====================================================
### ADVANCED API TEST SUITE
### =====================================================

@baseUrl = http://127.0.0.1:8000/api
@json = application/json
@ownerEmail = new_owner_2026@test.com
@ownerPassword = NewPass12345*
@secondOwnerEmail = new_vendorb_2026@test.com
@secondOwnerPassword = NewPass12345*
@customerEmail = new_customer_2026@test.com
@customerPassword = NewPass12345*
@adminEmail = new_admin_2026@test.com
@adminPassword = NewPass12345*

### =====================================================
### 0. HEALTH CHECK
### =====================================================

###
GET {{baseUrl}}/


### =====================================================
### 1. REGISTER USERS
### =====================================================

###
# @name ownerUser
POST {{baseUrl}}/auth/register/
Content-Type: {{json}}

{
  "username": "new_owner_user_2026",
  "email": "{{ownerEmail}}",
  "password": "{{ownerPassword}}",
  "role": "VENDOR_STAFF"
}


###
# @name secondOwnerUser
POST {{baseUrl}}/auth/register/
Content-Type: {{json}}

{
  "username": "new_vendor_b_owner_2026",
  "email": "{{secondOwnerEmail}}",
  "password": "{{secondOwnerPassword}}",
  "role": "VENDOR_STAFF"
}


###
# @name customerUser
POST {{baseUrl}}/auth/register/
Content-Type: {{json}}

{
  "username": "new_customer_user_2026",
  "email": "{{customerEmail}}",
  "password": "{{customerPassword}}",
  "role": "CUSTOMER"
}


###
# @name adminUser
POST {{baseUrl}}/auth/register/
Content-Type: {{json}}

{
  "username": "new_admin_user_2026",
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}",
  "role": "ADMIN"
}


### =====================================================
### 2. LOGIN USERS
### =====================================================

###
# @name loginOwner
POST {{baseUrl}}/auth/login/
Content-Type: {{json}}

{
  "email": "{{ownerEmail}}",
  "password": "{{ownerPassword}}"
}


###
# @name loginSecondOwner
POST {{baseUrl}}/auth/login/
Content-Type: {{json}}

{
  "email": "{{secondOwnerEmail}}",
  "password": "{{secondOwnerPassword}}"
}


###
# @name loginCustomer
POST {{baseUrl}}/auth/login/
Content-Type: {{json}}

{
  "email": "{{customerEmail}}",
  "password": "{{customerPassword}}"
}


###
# @name loginAdmin
POST {{baseUrl}}/auth/login/
Content-Type: {{json}}

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}


### =====================================================
### 3. CREATE VENDORS
### =====================================================

###
# @name vendorA
POST {{baseUrl}}/vendors/
Authorization: Bearer {{loginOwner.response.body.access}}
Content-Type: {{json}}

{
  "name": "Gamma Prestige Cars",
  "type": "COMPANY",
  "description": "Luxury fleet for high-end rentals"
}


###
# @name vendorB
POST {{baseUrl}}/vendors/
Authorization: Bearer {{loginSecondOwner.response.body.access}}
Content-Type: {{json}}

{
  "name": "Delta Rental Hub",
  "type": "COMPANY",
  "description": "Reliable city and airport rentals"
}


### =====================================================
### 4. LIST AND FILTER VENDORS
### =====================================================

###
GET {{baseUrl}}/vendors/
Authorization: Bearer {{loginOwner.response.body.access}}


###
GET {{baseUrl}}/vendors/?type=COMPANY
Authorization: Bearer {{loginOwner.response.body.access}}


###
GET {{baseUrl}}/vendors/?is_verified=false
Authorization: Bearer {{loginOwner.response.body.access}}


### =====================================================
### 5. UPDATE AND VERIFY VENDOR
### =====================================================

###
PUT {{baseUrl}}/vendors/{{vendorA.response.body.id}}/
Authorization: Bearer {{loginOwner.response.body.access}}
Content-Type: {{json}}

{
  "name": "Gamma Prestige Cars Updated",
  "type": "COMPANY",
  "description": "Updated luxury fleet description"
}


###
GET {{baseUrl}}/vendors/{{vendorA.response.body.id}}/
Authorization: Bearer {{loginOwner.response.body.access}}


### =====================================================
### 6. ADD VENDOR MEMBER
### =====================================================

###
# @name vendorMemberA
POST {{baseUrl}}/vendor-members/
Authorization: Bearer {{loginOwner.response.body.access}}
Content-Type: {{json}}

{
  "vendor": "{{vendorA.response.body.id}}",
  "user": "{{secondOwnerUser.response.body.id}}",
  "role": "MANAGER"
}


###
GET {{baseUrl}}/vendor-members/?vendor={{vendorA.response.body.id}}
Authorization: Bearer {{loginOwner.response.body.access}}


### =====================================================
### 7. CREATE VEHICLES
### =====================================================

###
# @name car1
POST {{baseUrl}}/vehicles/
Authorization: Bearer {{loginSecondOwner.response.body.access}}
Content-Type: {{json}}

{
  "vendor": "{{vendorB.response.body.id}}",
  "make": "BMW",
  "model": "X5",
  "year": 2025,
  "license_plate": "GAMMA-001",
